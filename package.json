{
  "name": "@cib/bootstrap-theme",
  "version": "1.0.3-dev.0",
  "description": "Centralized Bootstrap theme for CIB company frontend projects.",
  "main": "dist/index.css",
  "style": "dist/index.css",
  "files": [
    "dist",
    "scss",
    "src"
  ],
  "scripts": {
    "build": "sass src/index.scss dist/index.css --load-path=node_modules",
    "watch": "sass src/index.scss dist/index.css --load-path=node_modules --watch",
    "test": "vitest run",
    "test:unit": "vitest run --reporter=default --reporter=junit --outputFile=target/vitest-reports/TEST-front-end.xml",
    "lint": "npm run lint:console || true; npm run lint:junit",
    "lint:console": "stylelint \"src/**/*.scss\" --formatter verbose",
    "lint:junit": "stylelint \"src/**/*.scss\" --custom-formatter ./scripts/junit-formatter.mjs -o lint-results.xml"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bootstrap",
    "theme",
    "scss",
    "cib"
  ],
  "author": "CIB",
  "license": "Apache-2.0",
  "dependencies": {
    "bootstrap": "^5.3.0"
  },
  "devDependencies": {
    "sass": "^1.60.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "bootstrap": "^5.3.0"
  }
}
