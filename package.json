{
  "name": "@cib/bootstrap-theme",
  "version": "1.0.2-dev.0",
  "description": "Centralized Bootstrap theme for CIB company frontend projects.",
  "main": "dist/index.css",
  "style": "dist/index.css",
  "files": [
    "dist",
    "scss",
    "src"
  ],
  "scripts": {
    "build": "sass src/index.scss dist/index.css --load-path=node_modules",
    "watch": "sass src/index.scss dist/index.css --load-path=node_modules --watch",
    "test": "vitest run",
    "test:unit": "vitest run --coverage --reporter=default --reporter=junit --outputFile=target/vitest-reports/TEST-front-end.xml"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bootstrap",
    "theme",
    "scss",
    "cib"
  ],
  "author": "CIB",
  "license": "Apache-2.0",
  "dependencies": {
    "bootstrap": "^5.3.0"
  },
  "devDependencies": {
    "@vitest/coverage-istanbul": "3.2.4",
    "sass": "^1.60.0",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "bootstrap": "^5.3.0"
  }
}
