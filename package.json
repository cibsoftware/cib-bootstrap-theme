{
  "name": "@cib/bootstrap-theme",
  "version": "1.0.0-dev.2",
  "description": "Centralized Bootstrap theme for CIB company frontend projects.",
  "main": "dist/index.css",
  "style": "dist/index.css",
  "files": [
    "dist",
    "scss",
    "src"
  ],
  "scripts": {
    "build": "sass src/index.scss dist/index.css --load-path=node_modules",
    "watch": "sass src/index.scss dist/index.css --load-path=node_modules --watch"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "bootstrap",
    "theme",
    "scss",
    "cib"
  ],
  "author": "CIB",
  "license": "Apache-2.0",
  "dependencies": {
    "bootstrap": "^5.3.0"
  },
  "devDependencies": {
    "sass": "^1.60.0"
  },
  "peerDependencies": {
    "bootstrap": "^5.3.0"
  }
}
